#InControl
[incontrol]
	Enable = true

#Snowy Spirit
[snowyspirit]
	Enable = true
	#Enable special time with SnowySpirit.
	SpecialTime = true
	#Solar Terms in which Snowy Spirit villager AI behaviors will be active.
	WinterTime = ["BEGINNING_OF_WINTER", "LIGHT_SNOW", "HEAVY_SNOW", "WINTER_SOLSTICE", "LESSER_COLD", "GREATER_COLD"]

#Domum Ornamentum
[domum_ornamentum]
	#Enable automatic snow-covered blocks and models.
	Enable = true

#Haunted Harvest
[hauntedharvest]
	Enable = true
	#Solar Terms in which Haunted Harvest villager AI behaviors will be active.
	"Halloween Time" = ["COLD_DEW", "FIRST_FROST"]
	#Adds custom times in which mobs can wear pumpkins. Leave empty to ignore.
	" Mobs Wear Pumpkins Time" = ["FIRST_FROST"]

#MineColonies
[minecolonies]
	Enable = true
	# Default: 12000
	# Range: 1 ~ 23999
	AverageNightTime = 12000
	# Default: 1000
	# Range: -6000 ~ 6000
	CheckSleepOffset = 1000
